<?php

// ─────────────────────────────────────────────
// 1. bootstrap/app.php  (Laravel 11+)
// ─────────────────────────────────────────────
// Registar os dois middlewares com alias:

return Application::configure(basePath: dirname(__DIR__))
    ->withMiddleware(function (Middleware $middleware) {
        $middleware->alias([
            // Verifica apenas se a feature existe no plano
            'plan.feature' => \App\Http\Middleware\CheckPlanFeature::class,

            // Verifica feature + limite numérico vs. uso actual
            'plan.limit'   => \App\Http\Middleware\CheckPlanFeatureLimit::class,
        ]);
    })
    ->withProviders([
        // Registar as Blade directives
        App\Providers\PlanFeatureServiceProvider::class,
    ]);


// ─────────────────────────────────────────────
// 2. Exemplos de uso nas rotas (routes/web.php)
// ─────────────────────────────────────────────

// Protege a rota inteira: o utilizador precisa de ter a feature 'chatbot_lines'
Route::get('/chatbot', [ChatbotController::class, 'index'])
    ->middleware('plan.feature:chatbot_lines');

// Ao criar um membro: verifica o limite de 'members' contando TeamMember pelo team_id
Route::post('/teams/{team}/members', [TeamMemberController::class, 'store'])
    ->middleware('plan.limit:members,App\Models\TeamMember,team_id');

// Ao criar uma instância WhatsApp: verifica o limite de 'whatsapp_instances'
Route::post('/whatsapp/instances', [WhatsappController::class, 'store'])
    ->middleware('plan.limit:whatsapp_instances,App\Models\WhatsappInstance,user_id');


// ─────────────────────────────────────────────
// 3. Uso no Controller
// ─────────────────────────────────────────────

class TeamMemberController extends Controller
{
    public function __construct(
        private readonly PlanFeatureService $planFeature
    ) {}

    public function store(Request $request, Team $team)
    {
        $user = auth()->user();

        // Verificação manual (alternativa ao middleware)
        $currentMembers = $team->members()->count();
        if (!$this->planFeature->canUse($user, 'members', $currentMembers)) {
            return back()->withErrors([
                'plan' => 'Limite de membros atingido. Faça upgrade do seu plano.',
            ]);
        }

        // ... lógica de criação
    }

    public function index(Team $team)
    {
        $user = auth()->user();

        return inertia('Teams/Members', [
            'members'       => $team->members,
            'planFeatures'  => app(PlanFeatureService::class)->summary($user),
            // Ex: ['members' => ['value' => 5, 'unlimited' => false, 'limit' => 5]]
        ]);
    }
}


// ─────────────────────────────────────────────
// 4. Exemplos em Blade
// ─────────────────────────────────────────────

